---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ResearchCard from "../components/ResearchCard.astro";
---

<BaseLayout title="Research" description="Research in ML for astrophysics and cosmology by Pratik Dongre.">
  <section class="mx-auto max-w-5xl px-6 py-16">
    <SectionHeading
      title="Research"
      subtitle="Applying machine learning to problems in cosmology and astrophysics — from parameter inference to simulation acceleration."
    />

    <div class="space-y-8">
      <!-- CosmoMamba (featured) -->
      <ResearchCard
        featured
        title="CosmoMamba: State-Space Models for Cosmological Parameter Inference from 2D Field Maps"
        venue="Independent Research"
        year="2025"
        description="First application of selective state-space models (Mamba) to cosmological field analysis. CosmoMamba processes 256x256 field maps through multi-directional scans, achieving O(n) complexity. Benchmarked against CNNs and Vision Transformers on the CAMELS Multifield Dataset for predicting matter density (Omega_m) and fluctuation amplitude (sigma_8)."
        tags={["Mamba / SSM", "PyTorch", "Cosmology", "CAMELS", "Vision"]}
        links={[
          { label: "Zenodo (DOI)", href: "https://doi.org/10.5281/zenodo.19572872" },
          { label: "GitHub", href: "https://github.com/cosmic-ash/cosmo-mamba" },
        ]}
      >
        <div class="mt-6 overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead>
              <tr class="border-b border-slate-700 text-xs uppercase tracking-wider text-slate-500">
                <th class="pb-2 pr-4 font-medium">Model</th>
                <th class="pb-2 pr-4 font-medium">Params</th>
                <th class="pb-2 pr-4 font-medium">R&sup2;(&Omega;<sub>m</sub>)</th>
                <th class="pb-2 pr-4 font-medium">R&sup2;(&sigma;<sub>8</sub>)</th>
                <th class="pb-2 pr-4 font-medium">RMSE(&Omega;<sub>m</sub>)</th>
                <th class="pb-2 font-medium">RMSE(&sigma;<sub>8</sub>)</th>
              </tr>
            </thead>
            <tbody class="text-slate-300">
              <tr class="border-b border-slate-800/50">
                <td class="py-2 pr-4">CNN</td>
                <td class="py-2 pr-4 font-mono text-xs">1.1M</td>
                <td class="py-2 pr-4 font-mono text-xs font-semibold text-emerald-400">0.993</td>
                <td class="py-2 pr-4 font-mono text-xs font-semibold text-emerald-400">0.978</td>
                <td class="py-2 pr-4 font-mono text-xs">0.010</td>
                <td class="py-2 font-mono text-xs">0.018</td>
              </tr>
              <tr class="border-b border-slate-800/50">
                <td class="py-2 pr-4">ViT</td>
                <td class="py-2 pr-4 font-mono text-xs">10.9M</td>
                <td class="py-2 pr-4 font-mono text-xs">0.938</td>
                <td class="py-2 pr-4 font-mono text-xs">0.818</td>
                <td class="py-2 pr-4 font-mono text-xs">0.030</td>
                <td class="py-2 font-mono text-xs">0.052</td>
              </tr>
              <tr>
                <td class="py-2 pr-4 font-semibold text-indigo-400">CosmoMamba</td>
                <td class="py-2 pr-4 font-mono text-xs">4.0M</td>
                <td class="py-2 pr-4 font-mono text-xs">0.936</td>
                <td class="py-2 pr-4 font-mono text-xs font-semibold text-indigo-400">0.886</td>
                <td class="py-2 pr-4 font-mono text-xs">0.030</td>
                <td class="py-2 font-mono text-xs">0.041</td>
              </tr>
            </tbody>
          </table>
          <p class="mt-3 text-xs text-slate-500">
            CosmoMamba outperforms ViT on &sigma;<sub>8</sub> (R&sup2; = 0.886 vs 0.818) with 2.7x fewer parameters and O(n) complexity, and shows 30% less degradation in cross-suite transfer (IllustrisTNG &rarr; SIMBA).
          </p>
        </div>
      </ResearchCard>

      <!-- AGN Turbulence -->
      <ResearchCard
        title="Velocity Structure Function Analysis of AGN-Driven Turbulence"
        venue="National Tsing Hua University, Taiwan &mdash; with Dr. Hsiang-Yi Karen Yang"
        year="2021–2022"
        description="Analyzed turbulence properties in the intracluster medium (ICM) from AGN simulation datasets. Computed velocity structure functions and characterized turbulence parameters using Python's YT Project, contributing to understanding how AGN feedback drives ICM dynamics."
        tags={["Astrophysics", "ICM", "YT Project", "Python", "Turbulence"]}
      />

      <!-- N-body Simulation -->
      <ResearchCard
        title="Neural Network Acceleration of N-body Cosmological Simulations"
        venue="University of Hawaii"
        year="2021"
        description="Developed a deep neural network in PyTorch trained on cosmological simulation snapshots to accelerate N-body simulations, reducing runtime by 50+ hours per dataset. Engineered a reverse displacement field algorithm that optimized computational resource usage by 40%."
        tags={["PyTorch", "N-body Simulations", "Neural Emulators", "Cosmology"]}
      />

      <!-- CMB Deep Learning -->
      <ResearchCard
        title="Learning to Predict Cosmological Parameters Using Deep Learning"
        venue="IIIT Nagpur &mdash; B.Tech Final Year Project"
        year="2022"
        description="Extracted baryon density and dark matter density from Cosmic Microwave Background (CMB) maps using deep learning. Performed isotropy analysis of CMB data to test fundamental cosmological assumptions."
        tags={["CMB", "Deep Learning", "Cosmological Parameters", "Python"]}
        links={[
          { label: "ResearchGate", href: "https://www.researchgate.net/publication/360638628_Learning_to_predict_cosmological_parameters_using_Deep_Learning" },
        ]}
      />
    </div>
  </section>
</BaseLayout>
