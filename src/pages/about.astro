---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
---

<BaseLayout title="About" description="About Pratik Dongre — Data Scientist, ML Researcher, Writer.">
  <section class="mx-auto max-w-5xl px-6 py-16">
    <SectionHeading title="About" />

    <div class="flex flex-col lg:flex-row gap-12 lg:gap-16">
      <!-- Photo -->
      <div class="shrink-0">
        <div class="w-full max-w-sm lg:w-72 rounded-2xl overflow-hidden ring-1 ring-slate-800">
          <img
            src="/images/pratik.png"
            alt="Pratik Dongre camping in the Himalayas"
            class="w-full aspect-[4/5] object-cover"
          />
        </div>
      </div>

      <!-- Bio -->
      <div class="max-w-2xl space-y-5 text-slate-300 leading-relaxed">
        <p class="text-lg text-slate-200">
          I'm Pratik -- a Data Scientist by profession, a traveler by instinct, and a reader by passion.
        </p>

        <p>
          My work has taken me deep into machine learning, generative AI, and data-driven problem solving.
          I've published research, built AI applications, and experimented with ways technology can simplify
          complex worlds. But my heart often wanders to mountains, books, and the quiet spaces where ideas grow.
        </p>

        <p>
          On the research side, I apply deep learning to problems in cosmology. My most recent work,
          <a href="/research" class="text-indigo-400 hover:text-indigo-300 underline decoration-indigo-400/30 underline-offset-2 transition-colors">CosmoMamba</a>,
          is the first application of state-space models to cosmological parameter inference from 2D field maps.
          Before that, I studied AGN-driven turbulence at National Tsing Hua University in Taiwan with
          Dr. Hsiang-Yi Karen Yang, and worked on neural network acceleration of N-body simulations at
          the University of Hawaii.
        </p>

        <p>
          In industry, I've spent 3+ years at
          <a href="https://certifyos.com" target="_blank" rel="noopener noreferrer" class="text-indigo-400 hover:text-indigo-300 underline decoration-indigo-400/30 underline-offset-2 transition-colors">CertifyOS</a>
          building predictive analytics systems, NLP pipelines, and automated ETL infrastructure on
          millions of healthcare provider records using BigQuery, Python, and GCP.
        </p>

        <p>
          I studied Computer Science at IIIT Nagpur, where my final-year project used deep learning
          to extract cosmological parameters from Cosmic Microwave Background maps.
        </p>

        <p>
          Outside of work, I find meaning in Dostoevsky's questions, Murakami's surreal silences,
          and the slow life of roaming beyond routines. I
          <a href="https://medium.com/@pratikmdongre" target="_blank" rel="noopener noreferrer" class="text-indigo-400 hover:text-indigo-300 underline decoration-indigo-400/30 underline-offset-2 transition-colors">write on Medium</a>
          about books, ideas, travel, and the ways in which technology and philosophy intersect.
        </p>

        <p class="text-slate-400 italic">
          My dream is simple: to live widely, think deeply, and create things that outlast fleeting trends.
        </p>
      </div>
    </div>

    <!-- Contact -->
    <div class="mt-20 rounded-xl border border-slate-800 bg-slate-900/50 p-8">
      <h2 class="text-lg font-semibold text-white mb-6">Get in touch</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <a
          href="mailto:pratikmdongre@gmail.com"
          class="flex items-center gap-3 rounded-lg bg-slate-800/50 px-4 py-3 text-sm text-slate-300 ring-1 ring-inset ring-slate-700 hover:bg-slate-700 hover:text-white transition-colors"
        >
          <svg class="h-5 w-5 text-slate-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
          Email
        </a>
        <a
          href="https://www.linkedin.com/in/pratik-dongre-00b620177/"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 rounded-lg bg-slate-800/50 px-4 py-3 text-sm text-slate-300 ring-1 ring-inset ring-slate-700 hover:bg-slate-700 hover:text-white transition-colors"
        >
          <svg class="h-5 w-5 text-slate-500 shrink-0" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
        <a
          href="https://github.com/cosmic-ash"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 rounded-lg bg-slate-800/50 px-4 py-3 text-sm text-slate-300 ring-1 ring-inset ring-slate-700 hover:bg-slate-700 hover:text-white transition-colors"
        >
          <svg class="h-5 w-5 text-slate-500 shrink-0" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          GitHub
        </a>
        <a
          href="https://medium.com/@pratikmdongre"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 rounded-lg bg-slate-800/50 px-4 py-3 text-sm text-slate-300 ring-1 ring-inset ring-slate-700 hover:bg-slate-700 hover:text-white transition-colors"
        >
          <svg class="h-5 w-5 text-slate-500 shrink-0" fill="currentColor" viewBox="0 0 24 24">
            <path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zm7.42 0c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/>
          </svg>
          Medium
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
