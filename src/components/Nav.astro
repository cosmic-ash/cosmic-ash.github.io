---
const currentPath = Astro.url.pathname;

const links = [
  { href: "/", label: "Home" },
  { href: "/research", label: "Research" },
  { href: "/projects", label: "Projects" },
  { href: "/resume", label: "Resume" },
  { href: "/about", label: "About" },
];
---

<nav class="fixed top-0 z-50 w-full border-b border-slate-800/60 bg-slate-950/80 backdrop-blur-md">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
    <a href="/" class="text-lg font-bold tracking-tight text-white hover:text-indigo-400 transition-colors">
      PD
    </a>

    <button
      id="mobile-toggle"
      class="flex md:hidden items-center justify-center rounded-md p-2 text-slate-400 hover:text-white transition-colors"
      aria-label="Toggle navigation"
    >
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <div class="hidden md:flex items-center gap-1">
      {links.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            "rounded-md px-3 py-1.5 text-sm transition-colors",
            currentPath === href
              ? "bg-slate-800 text-white"
              : "text-slate-400 hover:bg-slate-800/50 hover:text-white",
          ]}
        >
          {label}
        </a>
      ))}
      <a
        href="https://medium.com/@pratikmdongre"
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-md px-3 py-1.5 text-sm text-slate-400 hover:bg-slate-800/50 hover:text-white transition-colors inline-flex items-center gap-1"
      >
        Blog
        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-800/60 px-6 py-3">
    {links.map(({ href, label }) => (
      <a
        href={href}
        class:list={[
          "block rounded-md px-3 py-2 text-sm transition-colors",
          currentPath === href
            ? "bg-slate-800 text-white"
            : "text-slate-400 hover:bg-slate-800/50 hover:text-white",
        ]}
      >
        {label}
      </a>
    ))}
    <a
      href="https://medium.com/@pratikmdongre"
      target="_blank"
      rel="noopener noreferrer"
      class="block rounded-md px-3 py-2 text-sm text-slate-400 hover:bg-slate-800/50 hover:text-white transition-colors"
    >
      Blog &nearr;
    </a>
  </div>
</nav>

<script>
  const toggle = document.getElementById("mobile-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => menu?.classList.toggle("hidden"));
</script>
